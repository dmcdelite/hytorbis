items.Slocgorm_Sanguine_Star.name = Sanguine Star
items.Slocgorm_Sanguine_Star.description = <i>The Hero of the Heart's Keyblade, shorter than most and unusual in its design (as far as Keyblades go), yet familiar to the denizens of Sloc Gorm.</i>

items.Slocgorm_Lantern.name = Lantern
items.Slocgorm_Lantern.description = <i>A handy flame-carrying device that can channel basic magic abilities.</i> \n\nPrimary & Secondary: \nCasts a <color is="#FFFFff">4 Fire</color> Damage melee burst for <color is="#FFFFff">2 Mana</color> that ignites targets.
items.Slocgorm_Stick.name = Hardened Stick
items.Slocgorm_Stick.description = <i>A big stick quickly hardened into a crude combat implement.</i> \n\nPrimary: \nCasts a <color is="#FFFFff">4 Elemental</color> Damage projectile for <color is="#FFFFff">1 Mana</color>. \n\nSecondary: \n<color is="#FFFFff">8 Physical</color> Damage Melee attack.

