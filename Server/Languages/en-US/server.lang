items.Slocgorm_Crystal_Quartz.name = Quartz
items.Slocgorm_Crystal_Quartz.description = <i>A cut piece of clear crystal, suitable for housing Force. Be it Saguinated or Gilded, the limitless potential to create miracles is now within your reach.</i> \n\nCan be synthesized into <item is="Slocgorm_Life_Crystal"/>s or <item is="Slocgorm_Light_Crystal"/>s at a <item is="Bench_Arcane"/> \nMore suitable to the synthesis of <item is="Slocgorm_Life_Crystal"/>s.
items.Slocgorm_Crystal_Amethyst.name = Amethyst
